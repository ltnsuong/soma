{
  "expo": {
    "name": "soma",
    "slug": "soma",
    "scheme": "soma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.soma"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0612",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.soma"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "c293f20f-f4a1-4779-9b31-2024df021e33"
      }
    },
    "owner": "sofiale",
    "plugins": [
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SOMA uses your approximate location to show real people nearby. Your exact position is never shared."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7B6EF6",
          "sounds": []
        }
      ]
    ]
  }
}
