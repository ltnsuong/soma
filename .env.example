# SOMA app (Expo) — copy to .env and fill in. .env is gitignored.
# EXPO_PUBLIC_* values are bundled into the client app (visible to users).

# AI provider
EXPO_PUBLIC_AI_PROVIDER=groq
EXPO_PUBLIC_AI_KEY=<your-groq-api-key>

# Backend base URL (your deployed Railway URL in production)
EXPO_PUBLIC_BACKEND_URL=http://localhost:3000

# Google OAuth (create OAuth client IDs at https://console.cloud.google.com/apis/credentials)
# Web client ID is used on web; iOS/Android client IDs for native builds. Leave blank to disable.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
